rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'fc781117@gmail.com';
    }
    function isOwner() {
      return signedIn() && (resource.data.createdBy == request.auth.uid || resource.data.createdByEmail == request.auth.token.email);
    }
    function isCreatingOwnDoc() {
      return signedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /cases/{caseId} {
      allow read: if signedIn();
      allow create: if isCreatingOwnDoc() || isAdmin();
      allow update, delete: if isAdmin() || isOwner();
    }

    match /registrations/{registrationId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin() || isOwner();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
